<div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-6 mb-6 transition hover:border-purple-500">

    <!-- Category -->
    <div class="flex justify-between items-center mb-4">

        <a href="/category/<%= item.category.slug %>"
           class="px-4 py-2 rounded-full bg-purple-700 text-sm">

            <%= item.category.name %>

        </a>

        <span class="text-zinc-400 text-sm">

            <%= new Date(item.createdAt).toLocaleDateString() %>

        </span>

    </div>



    <!-- Title -->
    <h2 class="text-2xl font-bold mb-4">

        <a href="/post/<%= item.slug %>"
           class="hover:text-purple-400">

            <%= item.title %>

        </a>

    </h2>



    <!-- Content -->
    <div id="content-<%= item._id %>"
         class="text-zinc-300 whitespace-pre-line leading-8">

        <%= item.content %>

    </div>



    <!-- Stats -->
    <div class="flex flex-wrap gap-5 mt-6 text-sm text-zinc-400">

        <span>
            👁️ <%= item.views || 0 %>
        </span>

        <button

id="likeBtn-<%= item._id %>"

type="button"

onclick="likePost('<%= item._id %>')"

class="hover:text-red-400"

>

❤️

<span id="likes-<%= item._id %>">

<%= item.likes || 0 %>

</span>

</button>

        <button
            type="button"
            onclick="toggleComment('<%= item._id %>')"
            class="hover:text-purple-400">

            💬 <%= item.commentsCount || 0 %>

        </button>

    </div>



    <!-- Comment Box -->

<div id="commentBox-<%= item._id %>"
class="hidden mt-5 space-y-4">


<% if(item.comments && item.comments.length){ %>

<% item.comments.forEach(c=>{ %>

<div class="p-4 rounded-xl bg-black/30">

<p class="font-semibold text-purple-400">

<%= c.name %>

</p>

<p class="text-zinc-300">

<%= c.comment %>

</p>


<% if(c.adminReply){ %>

<div class="mt-3 ml-4 border-l-4 border-purple-500 pl-4">

<p class="text-purple-400">

Admin Reply

</p>

<p>

<%= c.adminReply %>

</p>

</div>

<% } %>

</div>

<% }) %>

<% } %>



<form
action="/comment/<%= item._id %>"
method="POST"
class="space-y-3">

<input
name="name"
required
placeholder="Your Name"
class="w-full p-3 rounded-xl bg-black/40 border border-white/10">

<textarea
name="comment"
required
rows="3"
placeholder="Write your comment..."
class="w-full p-3 rounded-xl bg-black/40 border border-white/10">

</textarea>

<button
type="submit"
class="px-5 py-2 rounded-xl bg-purple-700">

Send

</button>

</form>

</div>





    <!-- Buttons -->
    <div class="flex flex-wrap gap-3 mt-6">

        <button
            onclick="copyShayari('content-<%= item._id %>')"
            class="px-5 py-2 rounded-xl bg-purple-700 hover:bg-purple-600">

            Copy

        </button>



        <a href="https://wa.me/?text=<%= encodeURIComponent(item.content) %>"
           target="_blank"
           class="px-5 py-2 rounded-xl bg-green-600">

            WhatsApp

        </a>



        <a href="https://www.facebook.com/sharer/sharer.php?u=https://yourdomain.com/post/<%= item.slug %>"
           target="_blank"
           class="px-5 py-2 rounded-xl bg-blue-600">

            Facebook

        </a>



        <a href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent(item.content) %>"
           target="_blank"
           class="px-5 py-2 rounded-xl bg-zinc-800">

            X

        </a>



        <button
            onclick="printCard('content-<%= item._id %>')"
            class="px-5 py-2 rounded-xl bg-orange-600">

            Print

        </button>

    </div>

</div>

<script>

document.addEventListener('DOMContentLoaded',()=>{

document.querySelectorAll('[id^="likeBtn-"]').forEach(btn=>{

const id = btn.id.replace('likeBtn-','');

if(localStorage.getItem('liked-'+id)){

btn.classList.add('text-red-500');

}

});

});


async function likePost(id){

const btn = document.getElementById('likeBtn-'+id);

if(localStorage.getItem('liked-'+id)){

btn.classList.add('text-red-500');

return;

}

const res = await fetch('/like/'+id,{

method:'POST'

});

const data = await res.json();

if(data.success){

document.getElementById(

'likes-'+id

).innerText = data.likes;

localStorage.setItem(

'liked-'+id,

'yes'

);

btn.classList.add('text-red-500');

}

}



function toggleComment(id){

const box = document.getElementById(

'commentBox-'+id

);

box.classList.toggle('hidden');

}



function copyShayari(id){

const text = document.getElementById(

id

).innerText;

navigator.clipboard.writeText(

text

);

alert('Copied');

}



function printCard(id){

let data = document.getElementById(

id

).innerHTML;

let win = window.open();

win.document.write(data);

win.print();

win.close();

}

</script>
