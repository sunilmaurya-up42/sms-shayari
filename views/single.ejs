<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>

<%= post.seoTitle || post.title %>

</title>

<meta
name="description"
content="<%= post.seoDescription || '' %>"
>

<meta
name="keywords"
content="<%= post.seoKeywords || '' %>"
>

<link
rel="stylesheet"
href="/css/output.css"
>

</head>


<body class="bg-black text-white">


<%- include('./partials/header') %>


<main class="max-w-7xl mx-auto px-4 py-10">


<div class="grid lg:grid-cols-4 gap-8">


<div class="lg:col-span-3">


<div

class="bg-white/5

border border-white/10

backdrop-blur-xl

rounded-3xl

p-8"

>


<!-- Category -->


<a

href="/category/<%= post.category?.slug || '' %>"

class="inline-block

bg-purple-700

px-4

py-2

rounded-full"

>

<%= post.category?.name || 'Uncategorized' %>

</a>



<h1

class="text-4xl

font-bold

mt-5"

>

<%= post.title %>

</h1>



<div

class="flex

gap-6

text-zinc-400

mt-4"

>

<span>

👁️ <%= post.views %>

</span>


<span>

❤️ <%= post.likes %>

</span>

</div>



<div

id="shayariContent"

class="mt-8

whitespace-pre-line

leading-9

text-lg"

>

<%= post.content %>

</div>



<!-- Share -->


<div

class="flex

flex-wrap

gap-3

mt-8"

>


<button

onclick="copyText()"

class="bg-purple-700

px-5

py-3

rounded-xl"

>

Copy

</button>



<a

target="_blank"

href="https://wa.me/?text=<%= encodeURIComponent(post.content) %>"

class="bg-green-600

px-5

py-3

rounded-xl"

>

WhatsApp

</a>



<a

target="_blank"

href="https://x.com/intent/post?text=<%= encodeURIComponent(post.content) %>"

class="bg-zinc-800

px-5

py-3

rounded-xl"

>

X

</a>



<button

onclick="window.print()"

class="bg-orange-600

px-5

py-3

rounded-xl"

>

Print

</button>


</div>


</div>

<!-- Comments -->


<div

class="mt-10

bg-white/5

rounded-3xl

border border-white/10

p-8"

>

<h2

class="text-2xl

font-bold

mb-6"

>

Comments

</h2>



<%

(comments || []).forEach(

item=>{

%>



<div

class="mb-6"

>

<h3

class="font-semibold"

>

<%= item.name %>

</h3>



<p

class="text-zinc-300"

>

<%= item.comment %>

</p>



<%

if(

item.adminReply

){

%>



<div

class="mt-3

ml-5

border-l-4

border-purple-500

pl-4"

>

<p

class="text-purple-400"

>

Admin Reply

</p>



<p>

<%= item.adminReply %>

</p>

</div>



<%

}

%>



</div>



<%

}

)

%>
</div>





<!-- Related -->


<div

class="mt-10"

>

<h2

class="text-2xl

font-bold

mb-5"

>

Related Shayari

</h2>



<div class="space-y-3">


<%

(relatedPosts || []).forEach(

item=>{

%>



<a

href="/post/<%= item.slug %>"

class="block

bg-white/5

border border-white/10

rounded-xl

p-4"

>

<%= item.title %>

</a>



<%

}

)

%>



</div>

</div>




</div>




<!-- Sidebar -->


<div>

<%- include('./partials/adsense') %>

</div>




</div>

</main>



<%- include('./partials/footer') %>



<script>

function copyText(){

navigator.clipboard

.writeText(

document.getElementById(

"shayariContent"

).innerText

)

.then(()=>{

alert("Copied");

})

.catch(()=>{

alert("Copy failed");

});

}

</script>



</body>

</html>
