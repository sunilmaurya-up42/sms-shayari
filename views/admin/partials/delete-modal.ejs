<!-- Delete Shayari Modal -->

<div
id="deleteModal"
class="fixed inset-0 hidden z-50 bg-black/70 backdrop-blur-sm"
>

<div class="min-h-screen flex items-center justify-center p-5">

<div
class="w-full max-w-md rounded-3xl border border-white/10 bg-zinc-900/90 backdrop-blur-xl shadow-2xl p-6"
>

<div class="text-center">

<div
class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-red-500/20"
>

<svg
xmlns="http://www.w3.org/2000/svg"
fill="none"
viewBox="0 0 24 24"
stroke-width="1.5"
stroke="currentColor"
class="h-8 w-8 text-red-400"
>

<path
stroke-linecap="round"
stroke-linejoin="round"
d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0z"
/>

<path
stroke-linecap="round"
stroke-linejoin="round"
d="M12 15.75h.007v.008H12v-.008z"
/>

</svg>

</div>


<h2 class="text-2xl font-bold text-white">

Delete Shayari

</h2>


<p class="mt-3 text-zinc-400">

Are you sure you want to delete this Shayari?

</p>

<p class="text-red-400 text-sm mt-2">

This action cannot be undone.

</p>


</div>



<div class="mt-8 flex justify-end gap-4">


<button

type="button"

onclick="closeDeleteModal()"

class="rounded-xl bg-zinc-700 px-5 py-3 text-white hover:bg-zinc-600"

>

Cancel

</button>




<form id="deleteForm" method="POST">

<button
type="submit"
class="rounded-xl bg-red-600 px-5 py-3 text-white hover:bg-red-500"
>

Delete

</button>

</form>



</div>


</div>

</div>

</div>



<script>


function openDeleteModal(id){

document.getElementById(
'deleteForm'
).action =
'/admin/shayari/delete/' + id;

document.getElementById(
'deleteModal'
)
.classList.remove(
'hidden'
);

}


function closeDeleteModal(){


document

.getElementById(

'deleteModal'

)

.classList

.add(

'hidden'

);


}



</script>
