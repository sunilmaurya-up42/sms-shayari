<!-- Delete Shayari Modal -->

<div
id="deleteModal"
class="fixed inset-0 hidden z-50 bg-black/70 backdrop-blur-sm"
>

<div class="min-h-screen flex items-center justify-center p-5">

<div
class="w-full max-w-md rounded-3xl border border-white/10 bg-zinc-900/90 backdrop-blur-xl shadow-2xl p-6"
>

<div class="text-center">

<h2 class="text-2xl font-bold text-white">
Delete Shayari
</h2>

<p class="mt-3 text-zinc-400">
Are you sure you want to delete this Shayari?
</p>

</div>


<form id="deleteForm" method="POST">

<div class="mt-8 flex justify-end gap-4">

<button
type="button"
onclick="closeDeleteModal()"
class="rounded-xl bg-zinc-700 px-5 py-3 text-white"
>
Cancel
</button>

<button
type="submit"
class="rounded-xl bg-red-600 px-5 py-3 text-white"
>
Delete
</button>

</div>

</form>

</div>

</div>

</div>

<script>

function openDeleteModal(id){

document.getElementById("deleteForm").action =
"/admin/shayari/delete/" + id;

document.getElementById("deleteModal")
.classList.remove("hidden");

}

function closeDeleteModal(){

document.getElementById("deleteModal")
.classList.add("hidden");

}

</script>
