<body class="bg-black text-white">

<div class="flex">

<%- include('../partials/sidebar') %>

<div class="flex-1 ml-64">

<%- include('./header') %>

<div class="p-6">

<h1 class="text-3xl font-bold mb-8">
Website Settings
</h1>

<% if(request && request.query.saved){ %>

<div class="mb-6 p-4 rounded-xl bg-green-600/20 border border-green-500 text-green-300">

✅ Settings Saved Successfully

</div>

<% } %>

<div class="bg-white/10 backdrop-blur-xl rounded-3xl border border-white/10 p-6">

<form
action="/admin/settings"
method="POST"
class="space-y-6">

<div>

<label class="block mb-2">

Site Name

</label>

<input
type="text"
name="siteName"
value="<%= settings.siteName || '' %>"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>


<div>

<label class="block mb-2">

Description

</label>

<textarea
name="siteDescription"
rows="4"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10"><%= settings.siteDescription || '' %></textarea>

</div>


<div>

<label class="block mb-2">

Phone

</label>

<input
type="text"
name="phone"
value="<%= settings.phone || '' %>"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>


<div>

<label class="block mb-2">

WhatsApp

</label>

<input
type="text"
name="whatsapp"
value="<%= settings.whatsapp || '' %>"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>


<div>

<label class="block mb-2">

Email

</label>

<input
type="email"
name="email"
value="<%= settings.email || '' %>"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>


<div>

<label class="block mb-2">

Address

</label>

<input
type="text"
name="address"
value="<%= settings.address || '' %>"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>


<div>

<label class="block mb-2">

Copyright Text

</label>

<input
type="text"
name="copyrightText"
value="<%= settings.copyrightText || '' %>"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>


<button
class="px-6 py-3 bg-purple-700 rounded-xl hover:bg-purple-600">

Save Settings

</button>

</form>

</div>

</div>

</div>

</div>

</body>
