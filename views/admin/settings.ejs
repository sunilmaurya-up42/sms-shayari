<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Settings | SMS Shayari</title>

<link rel="stylesheet" href="/css/output.css">

</head>


<body class="bg-black text-white">

<div class="flex">

<%- include('../partials/sidebar') %>

<div class="flex-1 ml-64">

<%- include('./header') %>

<div class="p-6">

<h1 class="text-3xl font-bold mb-8">

Website Settings

</h1>


<% if(request && request.query.saved){ %>

<div class="mb-6 p-4 rounded-xl bg-green-600/20 border border-green-500 text-green-300">

✅ Settings Saved Successfully

</div>

<% } %>



<div
class="bg-white/10
backdrop-blur-xl
rounded-3xl
border border-white/10
p-6">

<form
action="/admin/settings"
method="POST"
class="space-y-6">



<!-- Site Name -->

<div>

<label class="block mb-2">

Site Name

</label>

<input
type="text"
name="siteName"
value="<%= settings.siteName || 'SMS Shayari' %>"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>




<!-- Description -->

<div>

<label class="block mb-2">

Site Description

</label>

<textarea
name="siteDescription"
rows="4"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10"><%= settings.siteDescription || '' %></textarea>

</div>




<!-- Phone -->

<div>

<label class="block mb-2">

Phone Number

</label>

<input
type="text"
name="phone"
value="<%= settings.phone || '8887728576' %>"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>




<!-- WhatsApp -->

<div>

<label class="block mb-2">

WhatsApp Number

</label>

<input
type="text"
name="whatsapp"
value="<%= settings.whatsapp || '8887728576' %>"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>




<!-- Email -->

<div>

<label class="block mb-2">

Email

</label>

<input
type="email"
name="email"
value="<%= settings.email || 'sunilmauryasurila@gmail.com' %>"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>




<!-- Address -->

<div>

<label class="block mb-2">

Address

</label>

<input
type="text"
name="address"
value="<%= settings.address || '' %>"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>




<!-- Analytics -->

<div>

<label class="block mb-2">

Google Analytics ID

</label>

<input
type="text"
name="analyticsId"
value="<%= settings.analyticsId || '' %>"
placeholder="G-XXXXXXXX"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>




<!-- Adsense -->

<div>

<label class="block mb-2">

AdSense Code

</label>

<input
type="text"
name="adsenseCode"
value="<%= settings.adsenseCode || '' %>"
placeholder="ca-pub-xxxxxxxxxx"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>




<!-- Facebook -->

<div>

<label class="block mb-2">

Facebook URL

</label>

<input
type="text"
name="facebookUrl"
value="<%= settings.facebookUrl || '' %>"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>




<!-- X -->

<div>

<label class="block mb-2">

X URL

</label>

<input
type="text"
name="xUrl"
value="<%= settings.xUrl || '' %>"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>




<!-- Instagram -->

<div>

<label class="block mb-2">

Instagram URL

</label>

<input
type="text"
name="instagramUrl"
value="<%= settings.instagramUrl || '' %>"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>




<!-- Copyright -->

<div>

<label class="block mb-2">

Copyright Text

</label>

<input
type="text"
name="copyrightText"
value="<%= settings.copyrightText || '© SMS Shayari. All Rights Reserved.' %>"
class="w-full p-4 rounded-xl bg-black/40 border border-white/10">

</div>




<button
class="px-6 py-3 bg-purple-700 rounded-xl hover:bg-purple-600">

Save Settings

</button>

</form>

</div>

</div>

</div>

</div>

</body>

</html>
